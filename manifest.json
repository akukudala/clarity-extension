{
    "manifest_version": 3,
    "name": "Clarity",
    "version": "1.0",
    "description": "Makes manipulation visible in real time.",
    "permissions": ["storage", "activeTab", "scripting"],
    "host_permissions": ["<all_urls>"],
    "background": {
      "service_worker": "dist/service-worker.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["dist/content.js"],
        "run_at": "document_idle"
      }
    ],
    "action": {
      "default_popup": "src/popup/popup.html"
    }
  }